#!/usr/bin/env bash
# Wave Dev Health — setup
# Creates skill symlink + registers background nudge hook
set -e

INSTALL_DIR="$(cd "$(dirname "$0")" && pwd)"
SETTINGS_FILE="$HOME/.claude/settings.json"
STATE_DIR="$HOME/.wave-dev-health"
SKILLS_DIR="$HOME/.claude/skills"
SCRIPT_PATH="$INSTALL_DIR/plugins/wave-dev-health/scripts/wellness-check.sh"

# ── Create skill symlink ─────────────────────────────────────────
# Claude Code auto-discovers skills in ~/.claude/skills/*/SKILL.md
SKILL_TARGET="$SKILLS_DIR/pulse"

if [ -L "$SKILL_TARGET" ] || [ ! -e "$SKILL_TARGET" ]; then
  ln -snf "$INSTALL_DIR/plugins/wave-dev-health/skills/pulse" "$SKILL_TARGET"
  echo "  ✓ Linked /pulse skill"
else
  echo "  ✓ /pulse skill already exists"
fi

# ── Make scripts executable ──────────────────────────────────────
chmod +x "$INSTALL_DIR/plugins/wave-dev-health/scripts/"*.sh 2>/dev/null || true

# ── Register background nudge hook in settings.json ──────────────
# UserPromptSubmit hook runs wellness-check.sh on every prompt
RESPONSE_SCRIPT="$INSTALL_DIR/plugins/wave-dev-health/scripts/record-response.sh"

python3 -c "
import json, os

f = '$SETTINGS_FILE'
prompt_script = '$SCRIPT_PATH'
response_script = '$RESPONSE_SCRIPT'

try:
    settings = json.load(open(f))
except:
    settings = {}

if 'hooks' not in settings:
    settings['hooks'] = {}

changed = False

# UserPromptSubmit hook: wellness check on every prompt
ups = settings['hooks'].get('UserPromptSubmit', [])
if not any('wellness-check.sh' in str(h) for h in ups):
    ups.append({'matcher': '', 'hooks': [{'type': 'command', 'command': f'bash \"{prompt_script}\"', 'timeout': 5}]})
    settings['hooks']['UserPromptSubmit'] = ups
    changed = True
    print('  ✓ Registered prompt hook (health nudges)')

# Stop hook: record when Claude finishes responding
stop = settings['hooks'].get('Stop', [])
if not any('record-response.sh' in str(h) for h in stop):
    stop.append({'matcher': '', 'hooks': [{'type': 'command', 'command': f'bash \"{response_script}\"', 'timeout': 3}]})
    settings['hooks']['Stop'] = stop
    changed = True
    print('  ✓ Registered response hook (accurate break detection)')

if changed:
    json.dump(settings, open(f, 'w'), indent=2)
else:
    print('  ✓ Hooks already registered')
" 2>/dev/null || echo "  ⚠ Could not register hooks (update ~/.claude/settings.json manually)"

# ── Create state directory ───────────────────────────────────────
mkdir -p "$STATE_DIR/sessions"

# ── Onboarding: analyze coding history ───────────────────────────
python3 "$INSTALL_DIR/scripts/onboarding.py" 2>/dev/null || true

# ── Telemetry opt-in ────────────────────────────────────────────
# Enable anonymous telemetry by default (just nudge/break events, no code/prompts)
# User can disable with: echo '{"telemetry":false}' > ~/.wave-dev-health/config.json
python3 -c "
import json, os
f = '$STATE_DIR/config.json'
try:
    cfg = json.load(open(f))
except:
    cfg = {}
if 'telemetry' not in cfg:
    cfg['telemetry'] = True
    json.dump(cfg, open(f, 'w'), separators=(',', ':'))
    print('  ✓ Anonymous telemetry enabled (nudge/break counts only, no code)')
    print('    Disable: echo \'{}\"telemetry\":false{}' > ~/.wave-dev-health/config.json'.format('{', '}'))
" 2>/dev/null || true

# Send install ping
TELEMETRY_SCRIPT="$INSTALL_DIR/plugins/wave-dev-health/scripts/telemetry-ping.sh"
bash "$TELEMETRY_SCRIPT" install 2>/dev/null &

echo ""
echo "  Wave Dev Health ready. Nudges start now."
